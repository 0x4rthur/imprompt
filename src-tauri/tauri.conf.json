{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Imprompt",
  "version": "0.1.0",
  "identifier": "app.imprompt",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Imprompt",
        "width": 920,
        "height": 720,
        "minWidth": 720,
        "minHeight": 600,
        "maxWidth": 1100,
        "maxHeight": 1040,
        "resizable": true,
        "maximizable": false,
        "decorations": false,
        "shadow": true,
        "visible": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; font-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' ipc: http://ipc.localhost https:",
      "devCsp": "default-src 'self'; img-src 'self' data:; font-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; connect-src 'self' ipc: http://ipc.localhost https: http://localhost:5173 ws://localhost:5173"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": false,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDRGM0NFMkZGMzNBQjY3MzEKUldReFo2c3ovK0k4VCsvSVRMbGJHZU5RcnBjQnRUcjBoaGJJbnplNSszZFh5VE01ZDFHN3NkSU0K",
      "endpoints": [
        "https://github.com/0x4rthur/imprompt/releases/latest/download/latest.json"
      ]
    }
  }
}
